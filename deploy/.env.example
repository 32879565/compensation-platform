# 用法：
#   compose 环境：cp deploy/.env.example deploy/.env
#   本地直跑后端：cp deploy/.env.example backend/.env
# 注意：
#   1. POSTGRES_PASSWORD、COMP_SECRET_KEY 和 COMP_ENCRYPTION_KEY 都必须改为
#      彼此独立的强随机值（不变量8）。POSTGRES_PASSWORD 需 URL-safe
#      （避免 @ : / # % $ 等字符；含 $ 时 compose 需写成 $$）。
#   2. 改口令时下面两处 Postgres 口令必须同步改。
#   3. pgdata 卷已初始化后再改 POSTGRES_PASSWORD 不会改库口令，需重建卷或 ALTER ROLE。
POSTGRES_USER=comp
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=compensation

# 后端数据库连接串（本地直跑后端时连 localhost；compose 内部自行拼接，不读此行）
COMP_DATABASE_URL=postgresql+psycopg://comp:change-me-strong-password@localhost:5432/compensation

# JWT 签名密钥（必填，fail-closed）。生成：python -c "import secrets;print(secrets.token_urlsafe(48))"
COMP_SECRET_KEY=change-me-generate-a-long-random-secret

# PII 加密口令（必填，fail-closed）。任意高熵串；轮换需重新加密现有数据。
COMP_ENCRYPTION_KEY=change-me-generate-another-random-secret

# Compose/生产必须为 true；仅在 backend/.env 的本地 HTTP 直跑开发中设为 false。
COMP_COOKIE_SECURE=true
# 开发时开 Swagger：COMP_DEBUG=true（生产禁止）
COMP_DEBUG=false

# 钉钉企业内部应用。默认 sandbox，即使凭证完整也绝不会真实发送。
# Client Secret 只能放在未跟踪的 deploy/.env 或生产 secret manager，禁止放前端/VITE_*。
COMP_DINGTALK_MODE=sandbox
COMP_DINGTALK_APP_ID=
COMP_DINGTALK_CORP_ID=
COMP_DINGTALK_CLIENT_ID=
COMP_DINGTALK_CLIENT_SECRET=
COMP_DINGTALK_AGENT_ID=
COMP_DINGTALK_REVIEW_SESSION_TTL_MINUTES=15
COMP_DINGTALK_REVIEW_SESSION_MAX_ATTEMPTS=10
COMP_DINGTALK_REVIEW_SESSION_IP_MAX_ATTEMPTS=300
COMP_DINGTALK_REVIEW_SESSION_ATTEMPT_WINDOW_MINUTES=15
COMP_DINGTALK_REVIEW_LINK_TTL_HOURS=168
# 通讯录/考勤读取同样默认关闭。先配置并轮换凭证、确认应用权限，再显式改为 true。
COMP_DINGTALK_READ_SYNC_ENABLED=false
# 仅兼容 sandbox/旧测试发现逻辑；生产组织同步边界不得依赖根名称。
COMP_DINGTALK_STORE_ROOT_NAMES=潮发运营中心,九亩地,中山
# 职位必须是钉钉通讯录中的精确值；多个值只用英文逗号分隔，两组不得重叠。
COMP_DINGTALK_DINING_MANAGER_TITLES=店长
COMP_DINGTALK_KITCHEN_MANAGER_TITLES=厨房经理
# 生产权威边界。语法：正整数远端根部门ID:已有本地非门店锚点代码；多个映射用英文逗号。
# 远端根、本地锚点代码均须唯一，远端子树不得交叠，本地锚点也不得互为祖先/后代。
COMP_DINGTALK_ORG_ROOT_MAPPINGS=
# 仅校验外部调度器使用的 IANA 时区；应用和一次性任务不会自行安排执行时间。
COMP_DINGTALK_ORG_SYNC_TIMEZONE=Asia/Shanghai
COMP_DINGTALK_ORG_SYNC_FRESHNESS_MINUTES=5
# 仅准备开启 live 时填写钉钉可访问的 HTTPS 地址，例如 https://pay.example.com
COMP_DINGTALK_PUBLIC_BASE_URL=

# Optional local loopback-port overrides. Leave these unset for the standard
# 5432 / 8000 / 8080 mapping; an isolated E2E stack can choose alternate ports.
# COMP_POSTGRES_PORT=15432
# COMP_BACKEND_PORT=18000
# COMP_FRONTEND_PORT=18080

# 仅 docker compose --profile production 启用 Caddy TLS 网关时填写。域名必须
# 已解析到部署主机；Caddy 用它申请/续期证书。
COMP_PUBLIC_HOST=
COMP_ACME_EMAIL=
