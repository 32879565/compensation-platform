# 用法：
#   compose 环境：cp deploy/.env.example deploy/.env
#   本地直跑后端：cp deploy/.env.example backend/.env
# 注意：
#   1. 口令必须改为强口令（不变量8），且需 URL-safe（避免 @ : / # % $ 等字符，
#      口令会被内插进下面的连接串；含 $ 时 compose 需写成 $$）。
#   2. 改口令时下面两处必须同步改（POSTGRES_PASSWORD 与 COMP_DATABASE_URL 内的口令）。
#   3. pgdata 卷已初始化后再改 POSTGRES_PASSWORD 不会改库口令，需重建卷或用 ALTER ROLE。
POSTGRES_USER=comp
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=compensation

# 后端数据库连接串（本地直跑后端时连 localhost；compose 内部由 compose 文件自行拼接，不读此行）
COMP_DATABASE_URL=postgresql+psycopg://comp:change-me-strong-password@localhost:5432/compensation
