# 用法：
#   compose 环境：cp deploy/.env.example deploy/.env
#   本地直跑后端：cp deploy/.env.example backend/.env
# 注意：
#   1. 口令/密钥必须改为强随机值（不变量8）。POSTGRES_PASSWORD 需 URL-safe
#      （避免 @ : / # % $ 等字符；含 $ 时 compose 需写成 $$）。
#   2. 改口令时下面两处 Postgres 口令必须同步改。
#   3. pgdata 卷已初始化后再改 POSTGRES_PASSWORD 不会改库口令，需重建卷或 ALTER ROLE。
POSTGRES_USER=comp
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=compensation

# 后端数据库连接串（本地直跑后端时连 localhost；compose 内部自行拼接，不读此行）
COMP_DATABASE_URL=postgresql+psycopg://comp:change-me-strong-password@localhost:5432/compensation

# JWT 签名密钥（必填，fail-closed）。生成：python -c "import secrets;print(secrets.token_urlsafe(48))"
COMP_SECRET_KEY=change-me-generate-a-long-random-secret

# 本地 HTTP 开发把 cookie Secure 关掉（否则浏览器不发 refresh cookie）；生产务必 true
COMP_COOKIE_SECURE=false
# 开发时开 Swagger：COMP_DEBUG=true（生产禁止）
COMP_DEBUG=false
