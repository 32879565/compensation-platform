{
	# Caddy obtains and renews certificates automatically. Operators must set
	# COMP_PUBLIC_HOST to a DNS name that resolves to this host before enabling
	# the production profile.
	email {$COMP_ACME_EMAIL}
}

{$COMP_PUBLIC_HOST} {
	encode zstd gzip

	# These headers belong at the TLS edge, rather than the HTTP-only frontend
	# container. HSTS is emitted only after Caddy has established HTTPS.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'"
	}

	reverse_proxy frontend:80 {
		# Caddy's reverse-proxy defaults overwrite X-Forwarded-* with the
		# request's remote host and scheme. The frontend accepts them only when
		# this fixed container IP is the actual peer.
	}
}
